rules_version = '2';

service cloud.firestore {
  match /databases/{db}/documents {

    /* ========= BASE ========= */

    // ========= HELPERS BASE =========
    function isAuth() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    
    // Roles desde documento - CONTROL-STORE
    function controlStoreUserDocExists() {
      return isAuth() && exists(/databases/$(db)/documents/apps/control-store/users/$(uid()));
    }
    function controlStoreUserRole() {
      return isAuth() && controlStoreUserDocExists()
        ? get(/databases/$(db)/documents/apps/control-store/users/$(uid())).data.role
        : null;
    }
    
    // Roles desde documento - CONTROLREMITO (para otras apps)
    function userDocExists() {
      return isAuth() && exists(/databases/$(db)/documents/apps/controlRemito/users/$(uid()));
    }
    function userRole() {
      return isAuth() && userDocExists()
        ? get(/databases/$(db)/documents/apps/controlRemito/users/$(uid())).data.role
        : null;
    }
    
    function userBranchId() {
      return isAuth() && userDocExists()
        ? get(/databases/$(db)/documents/apps/controlRemito/users/$(uid())).data.branchId
        : null;
    }
    
    // Helpers para CONTROL-STORE
    function isControlStoreMaxDev() { return controlStoreUserRole() == 'maxdev'; }
    function isControlStoreAdmin()  { return controlStoreUserRole() == 'admin' || controlStoreUserRole() == 'maxdev'; }
    
    // Helpers para CONTROLREMITO y otras apps
    function isMaxDev() { return userRole() == 'maxdev'; }
    function isAdmin()  { return userRole() == 'admin' || userRole() == 'maxdev'; }
    function isFactory(){ return userRole() == 'factory'; }
    function isBranch() { return userRole() == 'branch'; }
    function isDelivery(){return userRole() == 'delivery'; }
    function isInvited() { return userRole() == 'invited'; }
    function isManager() { return userRole() == 'manager'; }
    
    // Operación y campos
    function isCreate() { return !exists(resource.path); }
    function isUpdate() { return exists(resource.path); }
    
    // Dueño por campo (e.g., userId/ownerId)
    function ownerIs(field) {
      return isAuth() && (
        (isCreate() && request.resource.data[field] == uid()) ||
        (isUpdate() && resource.data[field] == uid() && request.resource.data[field] == uid())
      );
    }
    
        // Inmutabilidad
        function unchanged(field) {
          return isUpdate() 
            ? (!(field in request.resource.data) || request.resource.data[field] == resource.data[field])
            : true;
        }
    
    // Inmutabilidad flexible - permite null/undefined
    function unchangedOrNull(field) {
      return isUpdate() 
        ? (
            // Si el campo existe en ambos, deben ser iguales
            (field in resource.data && field in request.resource.data && request.resource.data[field] == resource.data[field])
            // O si no existe en ninguno
            || (!(field in resource.data) && !(field in request.resource.data))
            // O si ambos son null
            || (resource.data[field] == null && request.resource.data[field] == null)
            // O si no existe en el original y es null en la actualización
            || (!(field in resource.data) && request.resource.data[field] == null)
            // O si es null en el original y no existe en la actualización
            || (resource.data[field] == null && !(field in request.resource.data))
          )
        : true;
    }
    
    // Tipos y validadores comunes
    function strBetween(field, min, max) {
      return request.resource.data[field] is string
          && request.resource.data[field].size() >= min
          && request.resource.data[field].size() <= max;
    }
    function nonEmptyString(field) {
      return request.resource.data[field] is string && request.resource.data[field].size() >= 1;
    }
    function isBool(field) { return request.resource.data[field] is bool; }
    function isInt(field) {
      return request.resource.data[field] is number
          && (request.resource.data[field] % 1) == 0;
    }
    function isTs(field) { return request.resource.data[field] is timestamp; }
    function isStringOrNull(field) {
      return !(field in request.resource.data) || request.resource.data[field] is string || request.resource.data[field] == null;
    }
    
    // Lectura pública por flag booleano del doc
    function publicRead(flagField) {
      return resource.data[flagField] == true;
    }
    
    

    /* ========= CONTROLFILE ========= */

    // ========= CONTROLFILE =========
    
    // Archivos
    match /files/{fileId} {
      // READ público necesario para shares públicos vía Cloudflare Worker
      // El control de acceso real está en shares/{token} que valida expiración y estado
      // Los datos sensibles están en B2, no en Firestore
      allow read: if true;
      allow create: if isAuth() && request.resource.data.userId == uid();
      allow update, delete: if isAuth() && resource.data.userId == uid();
    }
    
    // Carpetas
    match /folders/{folderId} {
      allow create: if isAuth() && request.resource.data.userId == uid();
      allow read, update, delete: if isAuth() && resource.data.userId == uid();
    }
    
    // Sesiones de upload
    match /uploadSessions/{sessionId} {
      allow create: if isAuth() && request.resource.data.uid == uid();
      allow read, update, delete: if isAuth() && resource.data.uid == uid();
    }
    
    // ========= SHARES (GLOBAL) =========
    match /shares/{shareId} {
      allow read, write: if true;
    }
    
    // Papelera
    match /trash/{trashId} {
      allow create: if isAuth() && request.resource.data.userId == uid();
      allow read, update, delete: if isAuth() && resource.data.userId == uid();
    }
    
    // Usuarios
    match /users/{userId} {
      allow create: if isAuth() && userId == uid();
      allow read, update, delete: if isAuth() && userId == uid();
    }
    
    

    /* ========= CONTROLGASTOS ========= */

    // ========= CONTROLGASTOS =========
    
    // Estructura organizada: apps/controlgastos/users/{userId}/...
    match /apps/controlgastos/users/{userId}/expenses/{expenseId} {
      allow read, write: if isAuth() && userId == uid();
      allow create: if isAuth() && userId == uid();
      allow update, delete: if isAuth() && userId == uid();
    }
    
    match /apps/controlgastos/users/{userId}/payments/{paymentId} {
      allow read, write: if isAuth() && userId == uid();
      allow create: if isAuth() && userId == uid();
      allow update, delete: if isAuth() && userId == uid();
    }
    
    match /apps/controlgastos/users/{userId}/receipts/{receiptId} {
      allow read, write: if isAuth() && userId == uid();
      allow create: if isAuth() && userId == uid();
      allow update, delete: if isAuth() && userId == uid();
    }
    
    match /apps/controlgastos/users/{userId}/recurring_items/{itemId} {
      allow read: if isAuth() && userId == uid();
      allow create: if isAuth() 
                    && userId == uid()
                    && request.resource.data.userId == userId;
      allow update: if isAuth() 
                    && userId == uid()
                    && resource.data.userId == userId;
      allow delete: if isAuth() 
                    && userId == uid()
                    && resource.data.userId == userId;
    }
    
    match /apps/controlgastos/users/{userId}/recurring_items_instances/{instanceId} {
      allow read: if isAuth() && userId == uid();
      allow create: if isAuth() 
                    && userId == uid()
                    && request.resource.data.userId == userId;
      allow update: if isAuth() 
                    && userId == uid()
                    && resource.data.userId == userId;
      allow delete: if isAuth() 
                    && userId == uid()
                    && resource.data.userId == userId;
    }
    
    match /apps/controlgastos/users/{userId}/settings/{settingId} {
      allow read, write: if isAuth() && userId == uid();
      allow create: if isAuth() && userId == uid();
      allow update, delete: if isAuth() && userId == uid();
    }
    
    // Colecciones globales de ControlGastos
    match /apps/controlgastos/categories/{categoryId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    
    // Reglas legacy para ControlGastos (temporal - compatibilidad hacia atrás)
    match /expenses/{expenseId} {
      allow read, write: if isAuth() && resource.data.userId == uid();
      allow create: if isAuth() && request.resource.data.userId == uid();
      allow update, delete: if isAuth() && resource.data.userId == uid();
    }
    
    match /payments/{paymentId} {
      allow read, write: if isAuth() && resource.data.userId == uid();
      allow create: if isAuth() && request.resource.data.userId == uid();
      allow update, delete: if isAuth() && resource.data.userId == uid();
    }
    
    match /invoices/{invoiceId} {
      allow read, write: if isAuth() && resource.data.userId == uid();
      allow create: if isAuth() && request.resource.data.userId == uid();
      allow update, delete: if isAuth() && resource.data.userId == uid();
    }
    

    /* ========= AUDIT ========= */

    match /apps/auditoria/owners/{ownerId}/{document=**} {
    
      allow read, write: if isAuth()
        && (
          uid() == ownerId ||
          request.auth.token.ownerId == ownerId
        );
    }
    
    match /apps/auditoria/owners/{ownerId}/empleados/{empleadoId} {
    
      // LECTURA
      allow read: if isAuth()
        && (
          uid() == ownerId ||
          request.auth.token.ownerId == ownerId
        );
    
      // CREAR
      allow create: if isAuth()
        && (
          // Owner puede crear siempre
          uid() == ownerId ||
    
          // Operario puede crear SOLO si la empresa está asignada
          (
            request.auth.token.ownerId == ownerId
            && request.resource.data.empresaId is string
            && request.resource.data.empresaId
               in get(
                 /databases/$(db)/documents/apps/auditoria/owners/$(ownerId)/usuarios/$(uid())
               ).data.empresasAsignadas
          )
        );
    
      // UPDATE / DELETE (permitido por ahora)
      allow update, delete: if isAuth()
        && (
          uid() == ownerId ||
          (
            request.auth.token.ownerId == ownerId
            && resource.data.empresaId is string
            && resource.data.empresaId
               in get(
                 /databases/$(db)/documents/apps/auditoria/owners/$(ownerId)/usuarios/$(uid())
               ).data.empresasAsignadas
          )
        );
    }
    

    /* ========= REPO ========= */

    // ========= CONTROLREPO RULES =========
    
    // Documento principal del usuario en ControlRepo
    match /apps/controlrepo/users/{userId} {
    
      // El usuario autenticado solo puede acceder a su propio documento
      allow read, write: if isAuth() && uid() == userId;
    
      // Subcolecciones del usuario (preferences, futuras)
      // NOTA: githubIntegration ya no se utiliza (GitHub OAuth eliminado)
      match /{subPath=**} {
        allow read, write: if isAuth() && uid() == userId;
      }
    }
    

    /* ========= EMAILS ========= */

    match /apps/emails/{document=**} {
      allow read: if true;
    }
    

    /* ========= VALENTIN ========= */

    /* ========= VALENTIN ========= */
    
    match /apps/valentin/respuestas/{docId} {
      allow read, write: if true;
    }

    /* ========= MUSIC ========= */

    // ========= MUSIC APP =========
    
    // Users can only access their own music data
    match /apps/{appId}/usuarios/{uid}/{document=**} {
      allow read, write: if isAuth() && uid() == uid;
    }
    
    // Profile data
    match /apps/{appId}/usuarios/{uid}/perfil/{profileId} {
      allow read, write: if isAuth() && uid() == uid;
      allow create: if isAuth() && uid() == uid;
    }
    
    // Analysis data
    match /apps/{appId}/usuarios/{uid}/analisis/{analysisId} {
      allow read, write: if isAuth() && uid() == uid;
      allow create: if isAuth() && uid() == uid 
        && nonEmptyString('timestamp')
        && isTs('timestamp');
    }
    
    // Known artists and ratings
    match /apps/{appId}/usuarios/{uid}/artistasConocidos/{artistId} {
      allow read, write: if isAuth() && uid() == uid;
      allow create: if isAuth() && uid() == uid
        && nonEmptyString('nombre')
        && nonEmptyString('pais');
    }

    /* ========= GAMES ========= */

    // ========= JUEGOS APP =========
    
    // Perfil del jugador y estadísticas: solo el dueño (mismo uid que en la ruta)
    match /apps/juegos/players/{uid} {
      allow read, write: if isAuth() && uid() == uid;
    
      match /gameStats/{gameId} {
        allow read, write: if isAuth() && uid() == uid;
      }
    }
    

    /* ========= CONTROLCHAT ========= */

    /* ========= CONTROL CHAT HELPERS ========= */
    
    function workspace(workspaceId) {
      return get(/databases/$(db)/documents/workspaces/$(workspaceId));
    }
    
    function member(workspaceId, userId) {
      return get(/databases/$(db)/documents/workspaces/$(workspaceId)/members/$(userId));
    }
    
    function isWorkspaceOwner(workspaceId) {
      return isAuth() && workspace(workspaceId).data.ownerId == uid();
    }
    
    function isWorkspaceMember(workspaceId) {
      return isAuth() &&
        exists(/databases/$(db)/documents/workspaces/$(workspaceId)/members/$(uid()));
    }
    
    function isWorkspaceAdmin(workspaceId) {
      return isWorkspaceMember(workspaceId) &&
        member(workspaceId, uid()).data.role == "admin";
    }
    
    function isWorkspaceManager(workspaceId) {
      return isWorkspaceOwner(workspaceId) || isWorkspaceAdmin(workspaceId);
    }
    
    function workspaceUser(workspaceId) {
      return isWorkspaceOwner(workspaceId) || isWorkspaceMember(workspaceId);
    }
    
    // Permitir lectura cuando el doc no existe (creación inicial del workspace/conversación)
    function workspaceExists(workspaceId) {
      return exists(/databases/$(db)/documents/workspaces/$(workspaceId));
    }
    function workspaceMemberExists(workspaceId, userId) {
      return exists(/databases/$(db)/documents/workspaces/$(workspaceId)/members/$(userId));
    }
    function conversationExists(workspaceId, conversationId) {
      return exists(/databases/$(db)/documents/workspaces/$(workspaceId)/conversations/$(conversationId));
    }
    function conversationMemberExists(workspaceId, conversationId, userId) {
      return exists(/databases/$(db)/documents/workspaces/$(workspaceId)/conversations/$(conversationId)/members/$(userId));
    }
    
    function messageAuthor() {
      return isAuth() && resource.data.authorId == uid();
    }
    
    function legacyMigrationPending(userId) {
      return isAuth()
        && uid() == userId
        && (
          !exists(/databases/$(db)/documents/users/$(userId)) ||
          !("migrationVersion" in get(/databases/$(db)/documents/users/$(userId)).data) ||
          get(/databases/$(db)/documents/users/$(userId)).data.migrationVersion < 2
        );
    }
    
    
    /* ========= USERS ========= */
    
    match /users/{userId} {
    
      allow read, write: if isAuth() && uid() == userId;
    
      match /preferences/{docId} {
        allow read, write: if isAuth() && uid() == userId;
      }
    
      match /notifications/{notificationId} {
        allow read, write: if isAuth() && uid() == userId;
      }
    }
    
    
    /* ========= WORKSPACES ========= */
    
    match /workspaces/{workspaceId} {
    
      allow read: if isAuth() && (
        !workspaceExists(workspaceId) ||
        workspaceUser(workspaceId)
      );
    
      allow create: if isAuth() &&
        request.resource.data.ownerId == uid();
    
      allow update: if isWorkspaceOwner(workspaceId) &&
        request.resource.data.ownerId == resource.data.ownerId;
    
      allow delete: if isWorkspaceOwner(workspaceId);
    
    
      match /members/{userId} {
    
        allow read: if isAuth() && (
          (userId == uid() && !workspaceMemberExists(workspaceId, userId)) ||
          workspaceUser(workspaceId)
        );
    
        allow create: if isWorkspaceManager(workspaceId) &&
          request.resource.data.userId == userId;
    
        allow update: if isWorkspaceManager(workspaceId);
    
        allow delete: if isWorkspaceManager(workspaceId) &&
          resource.data.userId != workspace(workspaceId).data.ownerId;
      }
    
    
      match /conversations/{conversationId} {
    
        allow read: if isAuth() && (
          !conversationExists(workspaceId, conversationId) ||
          workspaceUser(workspaceId)
        );
    
        allow create: if workspaceUser(workspaceId);
    
        allow update: if workspaceUser(workspaceId);
    
        allow delete: if isWorkspaceManager(workspaceId);
    
    
        match /members/{userId} {
          allow read: if isAuth() && (
            (userId == uid() && !conversationMemberExists(workspaceId, conversationId, userId)) ||
            workspaceUser(workspaceId)
          );
          allow create, update, delete: if workspaceUser(workspaceId);
        }
    
    
        match /messages/{messageId} {
    
          allow read: if workspaceUser(workspaceId);
    
          allow create: if workspaceUser(workspaceId);
    
          allow update: if messageAuthor();
    
          allow delete: if messageAuthor() || isWorkspaceManager(workspaceId);
    
    
          match /reactions/{reactionId} {
            allow read: if workspaceUser(workspaceId);
            allow write: if workspaceUser(workspaceId);
          }
        }
    
    
        match /threads/{threadId} {
          allow read, write: if workspaceUser(workspaceId);
        }
    
        match /pinned/{pinId} {
          allow read, write: if workspaceUser(workspaceId);
        }
      }
    
    
      match /attachments/{attachmentId} {
    
        allow read: if workspaceUser(workspaceId);
    
        allow create: if workspaceUser(workspaceId) &&
          request.resource.data.ownerId == uid();
    
        allow update: if workspaceUser(workspaceId) &&
          request.resource.data.ownerId == resource.data.ownerId;
    
        allow delete: if workspaceUser(workspaceId);
      }
    
    
      match /notes/{noteId} {
    
        allow read: if resource.data.ownerId == uid();
    
        allow create: if request.resource.data.ownerId == uid();
    
        allow update, delete: if resource.data.ownerId == uid();
    
    
        match /links/{linkId} {
          allow read, write: if resource.data.ownerId == uid();
        }
      }
    
    
      match /documents/{documentId} {
    
        allow read: if resource.data.ownerId == uid();
    
        allow create: if request.resource.data.ownerId == uid();
    
        allow update, delete: if resource.data.ownerId == uid();
    
    
        match /blocks/{blockId} {
          allow read, write: if resource.data.ownerId == uid();
        }
      }
    
    
      match /tags/{tagId} {
        allow read, write: if workspaceUser(workspaceId);
      }
    
      match /graphNodes/{nodeId} {
        allow read, write: if workspaceUser(workspaceId);
      }
    
      match /graphEdges/{edgeId} {
        allow read, write: if workspaceUser(workspaceId);
      }
    
      match /notifications/{notificationId} {
        allow read, write: if workspaceUser(workspaceId);
      }
    
      match /summaries/{summaryId} {
        allow read, write: if workspaceUser(workspaceId);
      }
    
      match /embeddings/{embeddingId} {
        allow read, write: if workspaceUser(workspaceId);
      }
    
      match /jobs/{jobId} {
        allow read, write: if workspaceUser(workspaceId);
      }
    
      match /events/{eventId} {
        allow read, write: if workspaceUser(workspaceId);
      }
    
      match /searchIndex/{indexId} {
        allow read, write: if workspaceUser(workspaceId);
      }
    
    }
    
    
    /* ========= LEGACY MIGRATION ========= */
    
    match /apps/control-chat/users/{userId} {
    
      allow read: if legacyMigrationPending(userId);
    
      allow write: if false;
    
      match /messages/{messageId} {
        allow read: if legacyMigrationPending(userId);
        allow write: if false;
      }
    }

    /* ========= HORARIOS ========= */

    /* ===============================
       HORARIOS – REGLAS ACTUALIZADAS
       =============================== */
    
    /* ========= HELPERS LOCALES ========= */
    
    // Obtiene el ownerId del usuario autenticado desde su documento
    function horariosUserOwnerId() {
      return isAuth()
        && exists(/databases/$(db)/documents/apps/horarios/users/$(uid()))
        ? get(/databases/$(db)/documents/apps/horarios/users/$(uid())).data.ownerId
        : null;
    }
    
    // Verifica si el usuario autenticado puede actuar en nombre de un ownerId dado.
    // Puede si: es el propio owner, o es un colaborador con ese ownerId, o tiene rol admin.
    function horariosCanActFor(ownerId) {
      return isAuth()
        && ownerId != null
        && (
          uid() == ownerId
          || (
            exists(/databases/$(db)/documents/apps/horarios/users/$(uid()))
            && get(/databases/$(db)/documents/apps/horarios/users/$(uid())).data.ownerId == ownerId
          )
        );
    }
    
    // Verifica si el usuario tiene rol admin dentro del sistema horarios
    function horariosIsAdmin() {
      return isAuth()
        && exists(/databases/$(db)/documents/apps/horarios/users/$(uid()))
        && get(/databases/$(db)/documents/apps/horarios/users/$(uid())).data.role == 'admin';
    }
    
    // Verifica si el usuario tiene rol operador dentro del sistema horarios
    function horariosIsOperador() {
      return isAuth()
        && exists(/databases/$(db)/documents/apps/horarios/users/$(uid()))
        && get(/databases/$(db)/documents/apps/horarios/users/$(uid())).data.role == 'operador';
    }
    
    // Verifica si el usuario tiene rol delivery dentro del sistema horarios
    function horariosIsDelivery() {
      return isAuth()
        && exists(/databases/$(db)/documents/apps/horarios/users/$(uid()))
        && get(/databases/$(db)/documents/apps/horarios/users/$(uid())).data.role == 'delivery';
    }
    
    // Shortcut: admin o operador (puede editar stock, hacer pedidos, etc.)
    function horariosIsAdminOrOperador() {
      return horariosIsAdmin() || horariosIsOperador();
    }
    
    // Shortcut: cualquier rol activo del sistema (admin, operador, delivery)
    function horariosIsAnyRole() {
      return horariosIsAdmin() || horariosIsOperador() || horariosIsDelivery();
    }
    
    
    /* ===============================
       PUBLIC COMPANIES
       =============================== */
    
    match /apps/horarios/publicCompanies/{slug} {
      allow read: if true;
    
      allow create: if isAuth()
        && request.resource.data.ownerId == uid();
    
      allow update, delete: if false;
    }
    
    /* ===============================
       PUBLIC SCHEDULES
       =============================== */
    
    match /apps/horarios/publicSchedules/{companySlug}/weeks/{weekId} {
      allow read: if true;
    
      allow create, update: if isAuth()
        && request.resource.data.ownerId == uid();
    
      allow delete: if false;
    }
    
    /* ===============================
       PUBLIC OWNERS
       =============================== */
    
    match /apps/horarios/publicOwners/{ownerId} {
      allow read: if true;
      allow write: if horariosCanActFor(ownerId);
    }
    
    /* ===============================
       USERS
       =============================== */
    
    match /apps/horarios/users/{userId} {
      // Un usuario puede leer su propio doc.
      // Un admin puede leer todos los usuarios de su mismo ownerId.
      allow read: if isAuth()
        && (
          userId == uid()
          || horariosCanActFor(
              get(/databases/$(db)/documents/apps/horarios/users/$(userId)).data.ownerId
            )
        );
    
      // Permitir listar usuarios del mismo ownerId
      allow list: if isAuth() && horariosCanActFor(
        get(/databases/$(db)/documents/apps/horarios/users/$(uid())).data.ownerId != null
          ? get(/databases/$(db)/documents/apps/horarios/users/$(uid())).data.ownerId
          : uid()
      );
    
      // Cualquier usuario autenticado puede crear su propio doc (registro inicial o por invitación)
      allow create: if isAuth() && userId == uid();
    
      // Un usuario puede actualizar su propio doc.
      // Un admin puede actualizar docs de su ownerId.
      allow update: if isAuth()
        && (
          userId == uid()
          || (
            resource.data.ownerId != null
            && horariosCanActFor(resource.data.ownerId)
          )
        );
    
      // Solo el propio usuario o el owner pueden borrar
      allow delete: if isAuth()
        && (
          userId == uid()
          || resource.data.ownerId == uid()
          || (
            resource.data.ownerId != null
            && horariosCanActFor(resource.data.ownerId)
          )
        );
    }
    
    
    /* ===============================
       INVITACIONES
       =============================== */
    
    match /apps/horarios/invitaciones/{docId} {
      // Lectura pública para validar tokens en el flujo de registro
      allow read: if true;
    
      // Cualquier autenticado puede crear (el admin crea links para sus colaboradores)
      allow create: if isAuth();
    
      // Solo el creador puede actualizar, O el usuario que usa el link (marca como usado)
      allow update: if isAuth()
        && (
          resource.data.createdBy == uid()
          || (
            request.resource.data.usedBy == uid()
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(["usedBy", "usedAt"])
          )
        );
    
      allow delete: if isAuth()
        && resource.data.createdBy != null
        && horariosCanActFor(resource.data.createdBy);
    }
    
    /* ===============================
       EMPLOYEES
       =============================== */
    
    match /apps/horarios/employees/{docId} {
      allow read: if true;
    
      allow create: if horariosCanActFor(request.resource.data.ownerId);
    
      allow update, delete: if horariosCanActFor(
        resource.data.ownerId != null
          ? resource.data.ownerId
          : request.resource.data.ownerId
      );
    }
    
    /* ===============================
       SHIFTS
       =============================== */
    
    match /apps/horarios/shifts/{docId} {
      allow read: if true;
    
      allow create: if horariosCanActFor(request.resource.data.ownerId);
      allow update: if horariosCanActFor(
        resource.data.ownerId != null
          ? resource.data.ownerId
          : request.resource.data.ownerId
      );
      allow delete: if horariosCanActFor(resource.data.ownerId);
    }
    
    /* ===============================
       SCHEDULES
       =============================== */
    
    match /apps/horarios/schedules/{docId} {
      allow read: if true;
    
      allow create: if horariosCanActFor(request.resource.data.ownerId);
    
      allow update, delete: if isAuth();
    }
    
    /* ===============================
       WEEKS (base + versiones)
       =============================== */
    
    match /apps/horarios/weeks/{baseWeekId} {
      allow read, write: if isAuth()
        && horariosCanActFor(
          resource != null ? resource.data.ownerId : request.resource.data.ownerId
        );
    
      match /versions/{versionNumber} {
        allow read, write: if isAuth()
          && horariosCanActFor(
            get(/databases/$(db)/documents/apps/horarios/weeks/$(baseWeekId)).data.ownerId
          );
      }
    }
    
    /* ===============================
       HISTORIAL (cambios de horarios)
       =============================== */
    
    match /apps/horarios/historial/{historialId} {
      allow read: if isAuth() && resource.data.createdBy == uid();
    
      allow create: if isAuth() && request.resource.data.createdBy == uid();
    
      allow update: if false;
    
      allow delete: if isAuth() && resource.data.createdBy == uid();
    }
    
    /* ===============================
       EMPLOYEE FIXED RULES
       =============================== */
    
    match /apps/horarios/employee_fixed_rules/{ruleId} {
      allow read: if horariosCanActFor(resource.data.ownerId);
    
      allow create: if horariosCanActFor(request.resource.data.ownerId);
    
      allow update, delete: if horariosCanActFor(
        resource.data.ownerId != null
          ? resource.data.ownerId
          : request.resource.data.ownerId
      );
    }
    
    /* ===============================
       CONFIG
       =============================== */
    
    match /apps/horarios/config/{docId} {
      allow read: if true;
    
      allow create: if horariosCanActFor(request.resource.data.ownerId);
    
      allow update, delete: if horariosCanActFor(
        resource.data.ownerId != null
          ? resource.data.ownerId
          : request.resource.data.ownerId
      );
    }
    
    /* ===============================
       SETTINGS
       =============================== */
    
    match /apps/horarios/settings/{ownerId} {
      allow read: if isAuth()
        && (
          ownerId == uid()
          || horariosCanActFor(ownerId)
        );
    
      allow create: if isAuth()
        && (
          ownerId == uid()
          || horariosCanActFor(ownerId)
        );
    
      allow update: if isAuth()
        && (
          ownerId == uid()
          || horariosCanActFor(ownerId)
        )
        && unchanged("ownerId");
    
      allow delete: if false;
    }
    
    /* ===============================
       TASKS
       =============================== */
    
    match /apps/horarios/tasks/{taskId} {
      allow read: if true;
    
      allow create: if horariosCanActFor(request.resource.data.ownerId);
    
      allow update, delete: if horariosCanActFor(
        resource.data.ownerId != null
          ? resource.data.ownerId
          : request.resource.data.ownerId
      );
    }
    
    /* ===============================
       DAILY ACTIONS / STATUS
       =============================== */
    
    match /apps/horarios/dailyActions/{ownerId} {
      allow read: if true;
      allow create, update, delete: if horariosCanActFor(ownerId);
    }
    
    match /apps/horarios/dailyActionStatus/{docId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }
    
    match /apps/horarios/dailyTaskStatus/{docId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }
    
    /* ===============================
       ENLACES PUBLICOS (pedidos WhatsApp)
       =============================== */
    
    match /apps/horarios/enlaces_publicos/{docId} {
      allow read: if true;
    
      allow create, update: if isAuth()
        && horariosCanActFor(request.resource.data.ownerId);
    
      allow delete: if isAuth()
        && horariosCanActFor(resource.data.ownerId);
    }
    
    /* ===============================
       PEDIDOS (grupos de productos)
       =============================== */
    
    match /apps/horarios/pedidos/{docId} {
      allow read: if true;
    
      allow create: if horariosCanActFor(request.resource.data.ownerId);
      allow update: if horariosCanActFor(
        resource.data.ownerId != null
          ? resource.data.ownerId
          : request.resource.data.ownerId
      );
      allow delete: if horariosCanActFor(resource.data.ownerId);
    }
    
    match /apps/horarios/pedidos/{docId}/{sub=**} {
      allow read: if true;
    
      allow create: if horariosCanActFor(request.resource.data.ownerId);
      allow update: if horariosCanActFor(
        resource.data.ownerId != null
          ? resource.data.ownerId
          : request.resource.data.ownerId
      );
      allow delete: if horariosCanActFor(resource.data.ownerId);
    }
    
    /* ===============================
       PRODUCTS (legacy — compatibilidad)
       Solo lectura pública. Escritura solo para admin.
       =============================== */
    
    match /apps/horarios/products/{docId} {
      allow read: if true;
    
      allow create: if horariosIsAdmin()
        && horariosCanActFor(request.resource.data.ownerId);
    
      allow update: if horariosIsAdmin()
        && horariosCanActFor(
          resource.data.ownerId != null
            ? resource.data.ownerId
            : request.resource.data.ownerId
        );
    
      allow delete: if horariosIsAdmin()
        && horariosCanActFor(resource.data.ownerId);
    }
    
    /* ===============================
       CATÁLOGO (productos del sistema nuevo)
       Solo admin puede crear/editar el catálogo.
       Todos los autenticados del mismo owner pueden leer.
       =============================== */
    
    match /apps/horarios/catalogo/{docId} {
      allow read: if horariosCanActFor(resource.data.ownerId);
    
      allow create: if horariosIsAdmin()
        && horariosCanActFor(request.resource.data.ownerId);
    
      allow update: if horariosIsAdmin()
        && horariosCanActFor(
          resource.data.ownerId != null
            ? resource.data.ownerId
            : request.resource.data.ownerId
        );
    
      allow delete: if horariosIsAdmin()
        && horariosCanActFor(resource.data.ownerId);
    }
    
    /* ===============================
       STOCK UBICACIONES (stock por sucursal)
       Cada usuario puede leer y editar solo el stock de su locationId.
       Admin puede leer y editar todos.
       =============================== */
    
    match /apps/horarios/stock_ubicaciones/{docId} {
      // Admin ve todo el stock de su ownerId.
      // Operador/delivery solo ve el stock de su locationId.
     allow read: if isAuth()
      && horariosCanActFor(resource.data.ownerId);
    
      // Crear: admin o operador, dentro de su ownerId
      allow create: if horariosIsAdminOrOperador()
        && horariosCanActFor(request.resource.data.ownerId);
    
      // Actualizar: admin (cualquier ubicación) o operador (solo su locationId)
      allow update: if (
      horariosIsAdmin()
      && horariosCanActFor(resource.data.ownerId)
    ) || (
      horariosIsOperador()
      && horariosCanActFor(resource.data.ownerId)
    );
    
      // Borrar: admin o operador (solo su locationId)
      allow delete: if horariosCanActFor(resource.data.ownerId)
        && (
          horariosIsAdmin()
          || (
            horariosIsOperador()
            && resource.data.locationId ==
              get(/databases/$(db)/documents/apps/horarios/users/$(uid())).data.locationId
          )
        );
    }
    
    /* ===============================
       STOCK MOVIMIENTOS (log de movimientos)
       =============================== */
    
    match /apps/horarios/stock_movimientos/{docId} {
      allow read: if horariosCanActFor(resource.data.ownerId);
    
      allow create: if horariosIsAdminOrOperador()
        && horariosCanActFor(request.resource.data.ownerId);
    
      allow update, delete: if false;
    }
    
    /* ===============================
       PEDIDOS FÁBRICA (pedidos internos entre sucursales)
       =============================== */
    
    match /apps/horarios/pedidos_fabrica/{docId} {
      // Cualquier colaborador autenticado puede leer pedidos de su ownerId
      allow read: if horariosCanActFor(resource.data.ownerId);
    
      // Admin y operador pueden crear pedidos
      allow create: if horariosIsAdminOrOperador()
        && horariosCanActFor(request.resource.data.ownerId);
    
      // Admin puede actualizar cualquier pedido (para cambiar estado a despachado/recibido)
      // Operador puede actualizar solo pedidos que creó (para cancelar borradores)
      allow update: if horariosCanActFor(
        resource.data.ownerId != null
          ? resource.data.ownerId
          : request.resource.data.ownerId
      ) && horariosIsAdminOrOperador();
    
      allow delete: if horariosIsAdmin()
        && horariosCanActFor(resource.data.ownerId);
    }
    
    /* ===============================
       REMITOS LOG (documentos de envío)
       =============================== */
    
    match /apps/horarios/remitos_log/{docId} {
      // Todos los colaboradores pueden leer remitos de su ownerId (delivery también)
      allow read: if horariosCanActFor(resource.data.ownerId);
    
      // Solo admin puede crear remitos (es quien despacha desde fábrica)
      allow create: if horariosIsAdminOrOperador()
      && horariosCanActFor(request.resource.data.ownerId);
    
      // Admin actualiza estado del remito (preparado → en_camino → entregado)
      // Delivery puede marcar en_camino
      allow update: if horariosCanActFor(resource.data.ownerId)
        && (horariosIsAdmin() || horariosIsDelivery());
    
      allow delete: if false;
    }
    
    /* ===============================
       RECEPCIONES LOG (confirmaciones de entrega)
       =============================== */
    
    match /apps/horarios/recepciones_log/{docId} {
      // Todos los colaboradores del ownerId pueden leer recepciones
    allow read: if isAuth() && (
      resource == null
      || horariosCanActFor(resource.data.ownerId)
    );
      // Admin y operador pueden confirmar recepciones
      allow create: if horariosIsAdminOrOperador()
        && horariosCanActFor(request.resource.data.ownerId);
    
      // Una recepción es inmutable una vez creada
      allow update, delete: if false;
    }
    
    /* ===============================
       COUNTERS (numeración secuencial)
       =============================== */
    
    match /apps/horarios/counters/{docId} {
      allow read: if isAuth();
    
      // Los counters se actualizan dentro de transacciones — cualquier autenticado puede
      allow write: if isAuth();
    }
    
    /* ===============================
       AUDIT LOGS
       =============================== */
    
    match /apps/horarios/audit_logs/{docId} {
      allow read: if horariosIsAdmin()
        && horariosCanActFor(resource.data.ownerId);
    
      allow create: if isAuth();
    
      allow update, delete: if false;
    }
    
    /* ===============================
       LOTS (vencimientos — VencApp)
       =============================== */
    
    match /apps/horarios/lots/{docId} {
      allow read: if horariosCanActFor(resource.data.ownerId);
    
      allow create: if horariosIsAdminOrOperador()
        && horariosCanActFor(request.resource.data.ownerId);
    
      allow update: if horariosIsAdminOrOperador()
        && horariosCanActFor(resource.data.ownerId);
    
      allow delete: if horariosIsAdminOrOperador()
        && horariosCanActFor(resource.data.ownerId);
    }
    
    /* ===============================
       WAREHOUSE ZONES (zonas del depósito — VencApp)
       =============================== */
    
    match /apps/horarios/warehouse_zones/{docId} {
      allow read: if horariosCanActFor(resource.data.ownerId);
    
      allow create: if horariosIsAdminOrOperador()
        && horariosCanActFor(request.resource.data.ownerId);
    
      allow update: if horariosIsAdminOrOperador()
        && horariosCanActFor(resource.data.ownerId);
    
      allow delete: if horariosIsAdmin()
        && horariosCanActFor(resource.data.ownerId);
    }
    
    /* ===============================
       GROUPS + CONVERSACIONES + MENSAJES
       (sistema de mensajería interna)
       =============================== */
    
    match /apps/horarios/groups/{groupId} {
      allow read: if horariosCanActFor(resource.data.ownerId);
    
      allow create: if horariosIsAdmin()
        && horariosCanActFor(request.resource.data.ownerId);
    
      allow update, delete: if horariosIsAdmin()
        && horariosCanActFor(resource.data.ownerId);
    }
    
    match /apps/horarios/conversaciones/{convId} {
      allow read: if horariosCanActFor(resource.data.ownerId);
    
      allow create: if horariosIsAdminOrOperador()
        && horariosCanActFor(request.resource.data.ownerId);
    
      allow update: if horariosCanActFor(resource.data.ownerId);
    
      allow delete: if horariosIsAdmin()
        && horariosCanActFor(resource.data.ownerId);
    }
    
    match /apps/horarios/mensajes/{msgId} {
      allow read: if horariosCanActFor(resource.data.ownerId);
    
      allow create: if horariosIsAdminOrOperador()
        && horariosCanActFor(request.resource.data.ownerId);
    
      allow update, delete: if false;
    }
    
    /* ===============================
       REMITOS LEGACY (solo lectura — datos históricos)
       No se escribe más acá, solo se lee pedido-publico
       =============================== */
    
    match /apps/horarios/remitos/{docId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if false;
    }
    /* ===============================
       GRUPOS CATÁLOGO
       =============================== */
    
    match /apps/horarios/grupos_catalogo/{docId} {
      allow read: if horariosCanActFor(resource.data.ownerId);
    
      allow create: if horariosIsAdmin()
        && horariosCanActFor(request.resource.data.ownerId);
    
      allow update, delete: if horariosIsAdmin()
        && horariosCanActFor(resource.data.ownerId);
    }
    
    /* ===============================
       STOCK ACTUAL (legacy)
       =============================== */
    
    match /apps/horarios/stock_actual/{docId} {
      allow read: if horariosCanActFor(resource.data.ownerId);
      allow create: if horariosIsAdminOrOperador()
        && horariosCanActFor(request.resource.data.ownerId);
      allow update, delete: if horariosIsAdminOrOperador()
        && horariosCanActFor(resource.data.ownerId);
    }
    match /apps/horarios/recepciones/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }
    
    

    /* ========= MAPPING ========= */

    // =============================================================
    // 🚨 ARCHIVO PARCIAL DE REGLAS – SE CONCATENA AUTOMÁTICAMENTE 🚨
    //
    // ⚠️ NO ES UN ARCHIVO DE REGLAS COMPLETO
    //
    // PROHIBIDO DEFINIR AQUÍ:
    // ❌ rules_version
    // ❌ service cloud.firestore
    // ❌ match /databases/{database}/documents
    //
    // 👉 Este archivo SOLO puede contener:
    //    match /ruta/{id} { ... }
    //
    // ❗ Si agregás un `match /databases/...`
    //    Firestore IGNORA estas reglas sin error visible.
    // =============================================================
    
    
    
      match /apps/mapping/schema/{docId} {
        allow read, write: if true;
      }
    
      match /schemaTemplates/{schemaId} {
        allow read: if true;
        allow write: if true; // Los templates del sistema se guardan automáticamente
      }
    
      match /mappings/{mappingId} {
        allow read, write: if true; // Permitir leer y escribir mapeos
      }
    
    
    

    /* ========= DENY POR DEFECTO ========= */

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
